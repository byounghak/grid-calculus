/// \file
/// \brief Compile-time version string for the gridcalc library.
///
/// The string is filled in by CMake's `configure_file` from the project's
/// `project(gridcalc VERSION ...)` declaration. Downstream code should read it
/// via `gridcalc::version()` rather than hard-coding any version literal.
/// \since 0.0.1

#pragma once

namespace gridcalc {

/// \brief Returns the gridcalc library version as a null-terminated C string.
/// \returns The semantic version of the build, e.g. `"0.0.1"`.
/// \since 0.0.1
[[nodiscard]] constexpr const char* version() noexcept {
    return "@gridcalc_VERSION@";
}

}  // namespace gridcalc
